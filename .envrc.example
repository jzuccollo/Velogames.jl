# Betfair Exchange API credentials for odds integration
# Copy this file to .envrc and fill in your credentials
# Then run `direnv allow` to load them
export BETFAIR_USERNAME="your_username"
export BETFAIR_PASSWORD="your_password"
export BETFAIR_APP_KEY="your_app_key"

# Anthropic API key for qualitative intelligence extraction (optional)
# Get one from https://console.anthropic.com
export ANTHROPIC_API_KEY="your_api_key"
